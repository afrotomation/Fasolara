# GraphQL server endpoint (development)
NEXT_PUBLIC_CLIENT_DEV=http://localhost:4000/api

# GraphQL server endpoint (production)
NEXT_PUBLIC_CLIENT_URI=https://your-production-server.vercel.app/api

# WebSocket endpoint for subscriptions
NEXT_PUBLIC_WS_URI=ws://localhost:4000/api

# NextAuth configuration
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:5000
